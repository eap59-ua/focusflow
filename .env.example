# -------------------------------------------------------------------
# FocusFlow — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# NUNCA commitees `.env`.
# -------------------------------------------------------------------

# --- Database ------------------------------------------------------
DATABASE_URL="postgresql://focusflow:focusflow@localhost:5432/focusflow?schema=public"

# --- Redis (BullMQ + rate limiting) --------------------------------
REDIS_URL="redis://localhost:6379"

# --- Auth (JWT firmado para cookies HttpOnly) ----------------------
# Cadena aleatoria de al menos 32 chars.
JWT_SECRET="change-me-to-a-random-32-plus-char-secret"

# --- Encryption at rest de los tokens OAuth ------------------------
# AES-256-GCM requiere 32 bytes -> 64 chars hex.
OAUTH_TOKEN_ENCRYPTION_KEY="change-me-64-hex-chars-exactly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Google OAuth (Gmail API) --------------------------------------
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# --- OpenAI --------------------------------------------------------
OPENAI_API_KEY=""

# --- Email delivery ------------------------------------------------
EMAIL_FROM="FocusFlow <no-reply@focusflow.local>"
# Opción A: SMTP via Nodemailer
SMTP_URL=""
# Opción B: Resend (si se usa en lugar de SMTP)
RESEND_API_KEY=""
