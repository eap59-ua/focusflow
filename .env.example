# -------------------------------------------------------------------
# FocusFlow — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# NUNCA commitees `.env`.
# -------------------------------------------------------------------

# --- Database ------------------------------------------------------
DATABASE_URL="postgresql://focusflow:focusflow@localhost:55432/focusflow?schema=public"

# --- Redis (BullMQ + rate limiting) --------------------------------
REDIS_URL="redis://localhost:6379"

# --- Sesiones HTTP (cookie httpOnly + persistencia en tabla sessions) -
SESSION_COOKIE_NAME="focusflow.session"
SESSION_LIFETIME_DAYS="30"

# --- Auth (JWT firmado para cookies HttpOnly) ----------------------
# Cadena aleatoria de al menos 32 chars.
JWT_SECRET="change-me-to-a-random-32-plus-char-secret"

# --- Encryption at rest de los tokens OAuth ------------------------
# AES-256-GCM requiere 32 bytes -> 64 chars hex. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=""

# --- Google OAuth (Gmail API) --------------------------------------
# Obtener en https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID.
# Redirect URI debe coincidir EXACTO con el registrado en Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3030/settings/gmail/callback"

# --- Gmail ingest job (defaults razonables, opcionales) ------------
GMAIL_FETCH_MAX_MESSAGES="50"
GMAIL_FETCH_QUERY="in:inbox newer_than:1d"

# --- OpenAI --------------------------------------------------------
# Obtener key en https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_INPUT_TOKENS="8000"

# --- Email delivery (SMTP) -----------------------------------------
# Dev: Mailpit local (docker-compose) — host=localhost, port=1025, sin auth.
# Prod: cambiar a SMTP del provider en Paso 8 (Resend/SES/etc.).
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM_ADDRESS="focusflow@local.dev"
EMAIL_FROM_NAME="FocusFlow"
