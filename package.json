{
  "name": "focusflow",
  "version": "0.0.1",
  "private": true,
  "description": "Morning briefing diario generado por IA desde tu bandeja de Gmail.",
  "author": "Erardo Aldana Pessoa",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n next,workers -c cyan,magenta \"next dev\" \"pnpm workers:dev\"",
    "workers:dev": "echo \"[workers] placeholder: aún no hay jobs BullMQ. Se arrancará tsx watch sobre src/jobs cuando existan.\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "echo \"[e2e] aún no configurado — Playwright llegará en la fase 5\" && exit 0",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.1",
    "@trpc/client": "^11.16.0",
    "@trpc/next": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "next": "^15.5.15",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "prisma": "^7.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
