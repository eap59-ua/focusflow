# -------------------------------------------------------------------
# FocusFlow — variables de entorno para TESTS DE INTEGRACIÓN
# Carga automática vía tests/integration/envSetup.ts.
# No contiene secretos reales: solo el Postgres local de docker-compose,
# apuntando a una BD aislada (focusflow_test) que se crea en globalSetup.
# -------------------------------------------------------------------

DATABASE_URL="postgresql://focusflow:focusflow@localhost:55432/focusflow_test?schema=public"
REDIS_URL="redis://localhost:6379"

SESSION_COOKIE_NAME="focusflow.session"
SESSION_LIFETIME_DAYS="30"

# Clave dummy para tests (no usar en prod). 64 chars hex.
TOKEN_ENCRYPTION_KEY="dead0000beef0000cafe0000babe0000face0000feed0000c0de0000abcd1234"
