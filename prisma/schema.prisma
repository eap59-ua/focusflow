// FocusFlow — Prisma schema
// Los modelos se añadirán en los slices sucesivos (User, Integration, Briefing, …).
// Ver docs/adr/0001-stack-y-arquitectura.md para el porqué del stack.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @db.Uuid
  email            String            @unique
  hashedPassword   String            @map("hashed_password")
  displayName      String            @map("display_name")
  briefingHour     Int               @default(8) @map("briefing_hour")
  briefingTimezone String            @default("Europe/Madrid") @map("briefing_timezone")
  briefingEnabled  Boolean           @default(false) @map("briefing_enabled")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions         Session[]
  gmailIntegration GmailIntegration?
  briefings        Briefing[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model GmailIntegration {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleAccountEmail    String   @map("google_account_email")
  accessTokenEncrypted  String   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String   @map("refresh_token_encrypted") @db.Text
  scope                 String
  tokenExpiresAt        DateTime @map("token_expires_at") @db.Timestamptz(6)
  connectedAt           DateTime @default(now()) @map("connected_at") @db.Timestamptz(6)
  lastRefreshedAt       DateTime @default(now()) @map("last_refreshed_at") @db.Timestamptz(6)

  @@map("gmail_integrations")
}

model Briefing {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary          String   @db.Text
  emailsConsidered Int      @map("emails_considered")
  emailsTruncated  Int      @map("emails_truncated")
  tokensUsedInput  Int      @map("tokens_used_input")
  tokensUsedOutput Int      @map("tokens_used_output")
  modelUsed        String   @map("model_used")
  promptVersion    String   @map("prompt_version")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)])
  @@map("briefings")
}
