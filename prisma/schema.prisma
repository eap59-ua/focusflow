// FocusFlow — Prisma schema
// Los modelos se añadirán en los slices sucesivos (User, Integration, Briefing, …).
// Ver docs/adr/0001-stack-y-arquitectura.md para el porqué del stack.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @db.Uuid
  email          String   @unique
  hashedPassword String   @map("hashed_password")
  displayName    String   @map("display_name")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}
